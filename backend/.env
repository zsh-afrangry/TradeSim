# backend/.env - 敏感 API Key 资产挂载中心
# ----------------------------------------
# 绝对隔离区：此文件严禁签入 Git，严禁暴漏于前端
# 只有服务端的 Python 应用（如 llm_agent.py 等）才能读取和解析

# 千问大模型 (Qwen) 或 OpenAI API_KEY 存放处
# 举例: sk-xxxxxxxxxxxxxxxxxxxxx
LLM_API_KEY=sk-d03f0fd890fc4581a4038807403e3629

# 可选: 指定模型名或者基准URL (如果是代理端)
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
