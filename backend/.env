# backend/.env - 环境配置与敏感 API Key 资产挂载中心
# ----------------------------------------
# 绝对隔离区：此文件严禁签入 Git，严禁暴露于前端
# 只有服务端的 Python 应用才能读取和解析

# ── 运行模式配置 ──────────────────────────────────────
# development : 联机开发模式，使用 MySQL + MongoDB
# standalone  : 本地打包交付，使用 SQLite + 本地 JSON（无需安装任何数据库服务）
APP_MODE=development

# ── 数据库连接（仅 development 模式读取）─────────────
MYSQL_URL=mysql+pymysql://root:root@127.0.0.1:3306/tradesim
MONGO_URL=mongodb://127.0.0.1:27017

# 千问大模型 (Qwen) 或 OpenAI API_KEY 存放处
LLM_API_KEY=sk-d03f0fd890fc4581a4038807403e3629
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
